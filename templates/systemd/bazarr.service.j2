#jinja2: lstrip_blocks: True
[Unit]
Description=Bazarr ({{ bazarr_identifier }})
{% for service in bazarr_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in bazarr_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}

[Service]
Type=simple
Environment="HOME={{ devture_systemd_docker_base_systemd_unit_home_path }}"
ExecStartPre=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ bazarr_container_stop_grace_time_seconds }} {{ bazarr_identifier }} 2>/dev/null || true'
ExecStartPre=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ bazarr_identifier }} 2>/dev/null || true'

ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} create \
			--rm \
			--name={{ bazarr_identifier }} \
			--log-driver=none \
			--user={{ bazarr_uid }}:{{ bazarr_gid }} \
			--cap-drop=ALL \
			--cap-add=SETUID \
			--cap-add=SETGID \
			--cap-add=CHOWN \
			--cap-add=FOWNER \
			--cap-add=DAC_OVERRIDE \
			--read-only \
			--network={{ bazarr_container_network }} \
			{% if bazarr_container_http_bind_port %}
			-p {{ bazarr_container_http_bind_port }}:{{ bazarr_container_http_port }} \
			{% endif %}
			--env-file={{ bazarr_base_path }}/env \
			--label-file={{ bazarr_base_path }}/labels \
			--mount type=bind,src={{ bazarr_data_path }},dst=/config \
			{% for volume in bazarr_container_additional_volumes %}
			--mount type={{ volume.type | default('bind' if '/' in volume.src else 'volume') }},src={{ volume.src }},dst={{ volume.dst }}{{ (',' + volume.options) if volume.options | default('') else '' }} \
			{% endfor %}
			# https://docs.linuxserver.io/misc/read-only/#how
			--tmpfs=/run:rw,exec,nosuid,size=128m \
			{% for arg in bazarr_container_extra_arguments %}
			{{ arg }} \
			{% endfor %}
			{{ bazarr_container_image }}

{% for network in bazarr_container_additional_networks %}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} network connect {{ network }} {{ bazarr_identifier }}
{% endfor %}

ExecStart={{ devture_systemd_docker_base_host_command_docker }} start --attach {{ bazarr_identifier }}

ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ bazarr_container_stop_grace_time_seconds }} {{ bazarr_identifier }} 2>/dev/null || true'
ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ bazarr_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ bazarr_identifier }}

[Install]
WantedBy=multi-user.target
